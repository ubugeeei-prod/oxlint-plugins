{
  "name": "@oxlint-plugins/core",
  "version": "0.0.0",
  "description": "Shared Rust native core (NAPI-RS) for the @oxlint-plugins oxlint plugins. Every plugin's rule logic is compiled into this single native addon; plugin packages are thin JavaScript facades that depend on it.",
  "keywords": [
    "napi-rs",
    "oxlint",
    "oxlint-plugin",
    "rust"
  ],
  "license": "MIT",
  "contributors": [
    {
      "name": "@ubugeeei",
      "url": "https://github.com/ubugeeei"
    },
    {
      "name": "@baseballyama",
      "url": "https://github.com/baseballyama"
    },
    {
      "name": "Blacksmith",
      "url": "https://www.blacksmith.sh/"
    },
    {
      "name": "OpenAI",
      "url": "https://openai.com/"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei-prod/oxlint-plugins.git",
    "directory": "npm/core"
  },
  "files": [
    "index.js",
    "native.js",
    "native.d.ts",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "main": "index.js",
  "types": "native.d.ts",
  "exports": {
    ".": {
      "types": "./native.d.ts",
      "require": "./index.js",
      "default": "./index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "napi build --platform --release --js native.js --dts native.d.ts",
    "build:debug": "napi build --platform --js native.js --dts native.d.ts",
    "prepack": "pnpm run build"
  },
  "napi": {
    "binaryName": "oxlint_plugins_core",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
